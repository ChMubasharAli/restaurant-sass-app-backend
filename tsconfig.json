{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./", // Bata raha hai ke source code kahan hai
    "outDir": "./dist", // Bata raha hai ke compiled files kahan jayengi
    "paths": {
      "@/*": ["./src/*"] // Optional: paths simplify karne ke liye
    },

    /* Environment Settings */
    "module": "esnext", // Backend/Fastify ke liye NodeNext behtar hai
    "moduleResolution": "bundler",
    "target": "es2023",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    /* Output Settings */
    "sourceMap": true, // Debugging ke liye
    "declaration": true, // Types generate karne ke liye
    "declarationMap": true,

    /* Strictness (Aapne false rakha hai, isliye wahi rehne diya) */
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,

    /* Additional Recommended Options */
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "moduleDetection": "force"
  },
  "include": ["src/**/*", "generated/**/*"],
  "exclude": ["node_modules", "dist", "generated"]
}
