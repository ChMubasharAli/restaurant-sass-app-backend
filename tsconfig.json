{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "NodeNext", // ← Change from "preserve"
    "moduleResolution": "NodeNext", // ← Change from "bundler"
    "target": "ES2023",
    "strict": true,
    "allowJs": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noImplicitAny": false,
    "sourceMap": true
  },
  "include": ["src/**/*", "src/generated/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "prisma",
    "prisma.config.ts",
    "*.config.ts"
  ]
}
